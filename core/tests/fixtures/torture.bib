% Torture fixture for the brace-aware tokenizer in researcher_core/bib.py (D20).
% Every hard case lives in this one file. The first five entries are ported verbatim from
% scripts/tests/fixtures/torture.bib (the M1 reference implementation); the rest are the
% constructs core adds on top of it.
%
% M1 cases:   nested braces; a quoted value carrying both a comma and braces; bare numeric
%             and bare macro values; a compact entry terminated by }} on its last field
%             line; a trailing comma; and the three skipped block types (@comment with a
%             comma AND braces, @preamble with backslashes, @string).
% Core cases: @string macros are EXPANDED, not left as the macro name; concatenation of a
%             macro with a literal; a parenthesis-delimited entry; LaTeX accents and
%             escaped punctuation; a braced corporate author that must not be split into
%             given/family; "and others"; an uppercase @ARTICLE type; a key with
%             punctuation; unknown fields that must survive; and a % line comment holding a
%             decoy @article that must NOT be parsed as an entry.
%
% Eleven real entries. The skipped blocks and the decoy must yield none of them.

@comment{Not an entry: it holds a comma, plus {nested {braces}} that a regex parser
         would happily mistake for a citation key.}

@preamble{"\newcommand{\noopsort}[1]{} \newcommand{\printfirst}[2]{#1}"}

@string{jbhi = {IEEE Journal of Biomedical and Health Informatics}}
@string{spec = {Special Issue on Determinism}}

% @article{decoy2099, title={A commented-out entry that must never be parsed}, year={2099}}

@article{nested2020,
  title={A {Nested {Deep}} Title, with comma},
  author={Doe, Jane and Roe, Richard},
  journal={Journal of Balanced Braces},
  year={2020},
  doi={10.1234/nested}
}

